P1_METER_URL=http://homewizard.local
KASA_SUBNETS=192.168.1.0/24

# Optional when running on a local machine or service manager.
PORT=5001

# Bonjour/mDNS service discovery for local network dashboards.
MDNS_ENABLED=1
MDNS_SERVICE_NAME=HomeWizard P1
# Advertise both a standard web service and an app-specific service.
MDNS_SERVICE_TYPES=_http._tcp,_homewizard-p1._tcp

MELCLOUD_USER=your-melcloud-email@example.com
MELCLOUD_PASS=your-melcloud-password
CLAUDE_API_KEY=your-claude-api-key
# Optional: set a stable Flask session secret for deployments.
FLASK_SECRET_KEY=generate-a-random-secret-here
# Tuya / Nedis local setup uses tinytuya's devices.json and optional
# tuya_devices.json files rather than env vars.
